{
	"FunctionName": "myol-presigned-url",
	"Runtime": "nodejs22.x",
	"Handler": "dist/index.handler",
	"MemorySize": 128,
	"Timeout": 10,
	"Architectures": [
		"arm64"
	],
	"Environment": {
		"Variables": {
			"S3_BUCKET": "{{ must_env `MYOL_DATA_BUCKET` }}"
		}
	},
	"Role": "{{ must_env `LAMBDA_ROLE_ARN` }}"
}
